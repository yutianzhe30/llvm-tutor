# =============================================================================
# An Ubuntu docker file for llvm-tutor that installs LLVM via apt. 
# 
# DEVELOPMENT MODE (recommended):
# Mount your local source code as a volume for rapid iteration:
#   docker run --rm -it -v $(pwd):/llvm-tutor --hostname=llvm-tutor llvm-tutor:llvm-21 /bin/bash
# 
# This allows you to edit files locally and build/test inside Docker.
#
# STATIC BUILD MODE:
# If you prefer the old behavior (copy source into image at build time):
#   docker build -f Dockerfile_ubuntu_apt -t=llvm-tutor:llvm-21 .
#   docker run --rm -it --hostname=llvm-tutor llvm-tutor:llvm-21 /bin/bash
# =============================================================================

FROM ubuntu:22.04

ENV LLVM_DIR=/usr/lib/llvm-21/
ENV TUTOR_DIR=/llvm-tutor

# 1. INSTALL DEPENDENCIES
# As `tzdata` gets installed automatically (AFAIK, Python depends on it), it
# will interrupt the set-up with a question about the time-zone to use. However,
# this is a non-interactive sessions and that won't work. Work around it by
# setting the time-zone here.
ENV TZ=Europe/London
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone
RUN apt-get update && apt-get install -y \
    git \
    cmake \
    ninja-build \
    build-essential \
    python3-minimal python3-pip\
    wget \
    libzstd-dev \
    software-properties-common \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Add LLVM apt repository (modern signed-by approach)
RUN wget -qO- https://apt.llvm.org/llvm-snapshot.gpg.key | tee /etc/apt/trusted.gpg.d/apt.llvm.org.asc > /dev/null
RUN add-apt-repository "deb http://apt.llvm.org/jammy/ llvm-toolchain-jammy-21 main"
RUN apt-get update
RUN apt-get install -y llvm-21 llvm-21-dev llvm-21-tools clang-21
RUN apt-get install -y python3-setuptools

# 2. INSTALL LIT
RUN pip3 install lit

# 3. CREATE MOUNT POINT FOR LOCAL SOURCE
# The source will be mounted here at runtime via -v flag
RUN mkdir -p $TUTOR_DIR

# Set working directory for convenience
WORKDIR $TUTOR_DIR
